{
  "inputs": [
    "mock_data/recruiter_export.csv",
    "mock_data/ats_blob.json",
    "mock_data/recruiter_notes.txt",
    "mock_data/resume.txt",
    "mock_data/resume_alice.txt"
  ],
  "output": "mock_data/output_projected.json",
  "fields": [
    { "path": "full_name", "type": "string", "required": true },
    { "path": "primary_email", "from": "emails[0]", "type": "string", "required": true },
    { "path": "phone", "from": "phones[0]", "type": "string", "required": true, "normalize": "E164" },
    { "path": "skills", "from": "skills[].name", "type": "string[]", "normalize": "canonical" }
  ],
  "include_confidence": true,
  "on_missing": "null"
}
